{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comptext.dev/schemas/air.schema.json",
  "title": "CompText AIR",
  "description": "Agent Intermediate Representation for CompText. AIR represents intent, plan, contracts, inputs, and outputs. Evidence hashes belong in evidence.schema.json.",
  "type": "object",
  "required": ["version", "intent", "goal", "pipeline", "outputs"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "enum": ["air-v0.1"]
    },
    "intent": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["audit", "summarize", "validate", "transform", "search", "plan", "unknown"]
        },
        "risk_category": {
          "type": "string"
        }
      }
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "inputs": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "required": ["kind", "value"],
        "additionalProperties": false,
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["path", "text", "url", "artifact", "repo", "query"]
          },
          "value": {
            "type": "string"
          },
          "digest": {
            "type": "string"
          }
        }
      }
    },
    "pipeline": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_-]*$"
      }
    },
    "contracts": {
      "type": "array",
      "default": [],
      "items": {
        "type": "string"
      }
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["kind"],
        "additionalProperties": false,
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["report", "json", "markdown", "artifact", "summary"]
          },
          "path": {
            "type": "string"
          },
          "schema": {
            "type": "string"
          }
        }
      }
    },
    "metadata": {
      "type": "object"
    }
  }
}
