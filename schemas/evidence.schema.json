{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CompText AIR Evidence Event",
  "description": "JSON schema for verifiable evidence events associated with AIR artifacts. Supports hash chains for replay safety.",
  "type": "object",
  "required": [
    "event_id",
    "air_hash",
    "timestamp",
    "executor",
    "event_type",
    "event_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "event_id": {
      "type": "string",
      "description": "Unique identifier for this evidence event."
    },
    "parent_event_hash": {
      "type": "string",
      "description": "SHA-256 hash of the previous evidence event in the chain.",
      "pattern": "^[a-f0-9]{64}$"
    },
    "air_hash": {
      "type": "string",
      "description": "SHA-256 hash of the associated AIR artifact (intent/plan).",
      "pattern": "^[a-f0-9]{64}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when the evidence was recorded."
    },
    "executor": {
      "type": "object",
      "required": ["id", "type"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["agent", "human", "system"] }
      }
    },
    "event_type": {
      "type": "string",
      "enum": ["start", "step", "artifact", "end", "error", "verification"]
    },
    "command": {
      "type": "string",
      "description": "The command or action that was executed."
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "hash"],
        "additionalProperties": false,
        "properties": {
          "key": { "type": "string" },
          "hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "hash"],
        "additionalProperties": false,
        "properties": {
          "key": { "type": "string" },
          "hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },
    "log_hash": {
      "type": "string",
      "description": "SHA-256 hash of the execution log.",
      "pattern": "^[a-f0-9]{64}$"
    },
    "event_hash": {
      "type": "string",
      "description": "SHA-256 hash of this event object (typically calculated over all other fields).",
      "pattern": "^[a-f0-9]{64}$"
    },
    "metadata": {
      "type": "object"
    }
  }
}
